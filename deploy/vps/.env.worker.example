# Required by docker-compose.yml
REDIS_PASSWORD=change-this-long-random-password
REDIS_URL=redis://:change-this-long-random-password@redis:6379

# Worker concurrency. Start conservative, then increase after watching VPS/9Router load.
IMAGE_WORKER_CONCURRENCY=5

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 9Router
# If 9Router runs directly on the VPS host:
NINEROUTER_BASE_URL=http://host.docker.internal:20128
NINEROUTER_API_KEY=your-9router-api-key

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=lkom-images
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
